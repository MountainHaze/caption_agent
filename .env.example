CAPTION_AGENT_HOST=127.0.0.1
CAPTION_AGENT_PORT=8000
CAPTION_AGENT_ARTIFACT_DIR=artifacts
CAPTION_AGENT_PERSON_REL_THRESHOLD=0.65
CAPTION_AGENT_OBJECT_REL_THRESHOLD=0.75

# llm provider: mock | openai | qwen
CAPTION_AGENT_LLM_PROVIDER=mock
CAPTION_AGENT_LLM_MODEL=gpt-4.1-mini
CAPTION_AGENT_LLM_BASE_URL=
CAPTION_AGENT_LLM_API_KEY=
CAPTION_AGENT_LLM_TEMPERATURE=0.1
CAPTION_AGENT_PROMPTS_CONFIG=configs/prompts.yaml

# provider-specific optional keys
OPENAI_API_KEY=
OPENAI_BASE_URL=
DASHSCOPE_API_KEY=
